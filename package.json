  "scripts": {
    "prepare": "husky && npm install pnpm --global",
    "commitmsg": "commitlint --edit",
    "start": "NODE_EXTRA_CA_CERTS=\"$PWD/ssl/rootCA.pem\" pnpx nx run www:serve",
    "lint": "pnpm ci:lint -- --fix",
    "test": "pnpx nx run-many --target=test --outputStyle=stream --parallel=1 -- --coverage.enabled --coverage.all",
    "format": "pnpx nx format:write",
    "htmlhint": "htmlhint apps/ libs/",
    "e2e": "pnpx nx run-many --target=e2e --outputStyle=stream --configuration=production",
    "clean:install": "./scripts/clean-install.sh",
    "git:cleanup": "./scripts/git-cleanup.sh",
    "update:screenshots:light": "tsx ./tools/pwa-screenshots.ts https://www.omega2k.de apps/www/public/screenshots/light light",
    "update:screenshots:dark": "tsx ./tools/pwa-screenshots.ts https://www.omega2k.de apps/www/public/screenshots/dark dark",
    "ci:commitlint": "sh ./scripts/ci-commitlint.sh",
    "ci:lint": "nx run-many --target=lint --outputStyle=stream --configuration=production",
    "ci:eslint": "eslint --config eslint.config.mjs --format gitlab --output-file gl-codequality.json",
    "ci:test": "LOGGER=OFF pnpx nx run-many --target=test --outputStyle=stream --configuration=production --coverage --collectCoverage --parallel=1 -- --coverage.enabled --coverage.all",
    "ci:www-e2e": "pnpx nx run www-e2e:e2e --outputStyle=stream --configuration=production",
    "ci:websocket-e2e": "pnpx nx run websocket-e2e:e2e --outputStyle=stream --configuration=production --host=127.0.0.1",
    "ci:build": "pnpx nx run-many --target=build --outputStyle=stream --configuration=production",
    "ci:build:db": "tsx ./tools/build-content-db.ts",
    "ci:copy:db": "./scripts/copy-content-database.sh",
    "ci:htmlhint": "htmlhint apps/ libs/ dist/",
    "ci:pipeline": "pnpm ci:lint && pnpm ci:eslint && pnpm ci:test && pnpm ci:websocket-e2e && pnpm ci:www-e2e && pnpm ci:build && pnpm ci:copy:db && pnpm ci:htmlhint",
    "release": "node ./scripts/release.mjs"
  },
