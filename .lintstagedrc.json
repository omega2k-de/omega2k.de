{
  "*.{ts,tsx,js,jsx}": ["prettier --write", "eslint --max-warnings=3 --fix"],
  "*.{css,scss}": ["prettier --write", "stylelint --fix"],
  "*": ["prettier --ignore-unknown --write"],
  "*.{flow,json,less,html,gql,graphql,md,yml,yaml}": ["prettier --write"],
  "*.{png,jpeg,jpg,gif,svg}": ["node ./scripts/compress-image.js"]
}
